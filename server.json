{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.b-shields/cmxflow",
  "title": "cmxflow",
  "description": "Composable, tunable cheminformatics workflows: prepare ligands, cluster, virtual screens, and more.",
  "version": "0.3.1",
  "websiteUrl": "https://b-shields.github.io/cmxflow/",
  "repository": {
    "url": "https://github.com/b-shields/cmxflow",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "cmxflow",
      "version": "0.3.1",
      "transport": { "type": "stdio" },
      "runtimeHint": "uvx",
      "runtimeArguments": [
        { "type": "positional", "value": "--from" },
        { "type": "positional", "value": "cmxflow" },
        { "type": "positional", "value": "cmxflow-mcp" }
      ]
    }
  ]
}
